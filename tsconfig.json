{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "types": ["node", "vite/client"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["publish-ui/*"]
    }
  },
  "include": [
    "App.tsx",
    "index.tsx",
    "vite.config.ts",
    "vitest.config.ts",
    "playwright.config.ts",
    "components/**/*.ts",
    "components/**/*.tsx",
    "hooks/**/*.ts",
    "hooks/**/*.tsx",
    "lib/**/*.ts",
    "lib/**/*.tsx",
    "types/**/*.ts",
    "worker/**/*.ts",
    "tests/**/*.ts",
    "tests/**/*.tsx",
    "publish-ui/**/*.ts",
    "publish-ui/**/*.tsx"
  ],
  "exclude": ["node_modules", "dist", "ref", ".spec-workflow"]
}
